// Trinity Finance - Prisma Schema
// PostgreSQL 15 via Prisma ORM
// All PII fields encrypted at rest (AES-256-GCM, AWS KMS)
// Soft deletes via deletedAt on all core models
// Full audit trail via AuditLog model

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Role {
  APPLICANT
  AGENT
  MANAGER
  OWNER
  BANK_USER
  ADMIN
}

enum OrgType {
  REFERRAL
  BANK
  INTERNAL
}

enum OrgTier {
  OWNER
  MANAGER
  AGENT
}

enum LoanType {
  EQUIPMENT_FINANCING
  INVOICE_FACTORING
  INVOICE_FINANCING
  LINE_OF_CREDIT
  MCA
  SBA
  UNSURE
  DEBT_RELIEF
}

enum ApplicationStatus {
  DRAFT
  IN_REVIEW
  DOCS_PENDING
  UNDERWRITING
  MATCHED
  OFFER_SELECTED
  FUNDED
  DECLINED
  SERVICING
  STALLED
}

enum StoplightStatus {
  PENDING
  GREEN
  YELLOW
  RED
}

enum DocType {
  GOVERNMENT_ID
  VOIDED_CHECK
  BANK_STATEMENT
  TAX_RETURN_BUSINESS
  TAX_RETURN_PERSONAL
  EQUIPMENT_QUOTE
  AR_AGING_REPORT
  SAMPLE_INVOICE
  CUSTOMER_LIST
  PNL_YTD
  BALANCE_SHEET
  DEBT_SCHEDULE
  BUSINESS_PLAN
  FRANCHISE_AGREEMENT
  REAL_ESTATE_APPRAISAL
  MCA_CONTRACT
  CREDIT_AUTHORIZATION
  OTHER
}

enum MatchStatus {
  PROPOSED
  OFFERED
  SELECTED
  DECLINED
}

enum MarketplaceListingStatus {
  ACTIVE
  SOLD
  CANCELLED
}

enum ServicingEventType {
  PAYMENT_RECEIVED
  BALANCE_CHECK
  REFINANCE_TRIGGER
  DELINQUENCY_ALERT
  EVERGREEN_TRIGGER
  STEP_UP_SUGGESTION
}

// ─────────────────────────────────────────────────────────────
// CORE IDENTITY
// ─────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  phone          String?
  role           Role      @default(APPLICANT)
  clerkId        String    @unique
  organizationId String?
  firstName      String?
  lastName       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization      Organization?     @relation("OrgMembers", fields: [organizationId], references: [id])
  memberships       OrgMembership[]
  applicantApps     Application[]     @relation("ApplicantApplications")
  agentApps         Application[]     @relation("AgentApplications")
  auditLogs         AuditLog[]        @relation("AuditActor")
  signatures        Signature[]
  plaidConnections  PlaidConnection[]

  @@index([clerkId])
  @@index([email])
  @@index([role])
}

model Organization {
  id        String    @id @default(cuid())
  name      String
  type      OrgType
  parentId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  parent      Organization?   @relation("OrgHierarchy", fields: [parentId], references: [id])
  children    Organization[]  @relation("OrgHierarchy")
  members     User[]          @relation("OrgMembers")
  memberships OrgMembership[]
  bankRules   BankRule[]
  matches     Match[]

  @@index([type])
  @@index([parentId])
}

model OrgMembership {
  id             String    @id @default(cuid())
  userId         String
  organizationId String
  tier           OrgTier
  bucketId       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([bucketId])
}

// ─────────────────────────────────────────────────────────────
// APPLICATION MASTER + LOAN-TYPE CHILDREN
// ─────────────────────────────────────────────────────────────

model Application {
  id               String            @id @default(cuid())
  loanType         LoanType
  status           ApplicationStatus @default(DRAFT)
  applicantUserId  String?
  referralAgentId  String?
  referralCode     String?
  resumeToken      String?           @unique
  creditMemo       Json?
  underwritingScore Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  applicant        User?             @relation("ApplicantApplications", fields: [applicantUserId], references: [id])
  referralAgent    User?             @relation("AgentApplications", fields: [referralAgentId], references: [id])
  quickApp         QuickApp?
  equipmentApp     EquipmentApp?
  factoringApp     FactoringApp?
  invoiceFinApp    InvoiceFinancingApp?
  locApp           LineOfCreditApp?
  mcaApp           MCAApp?
  sbaApp           SBAApp?
  unsureApp        UnsureApp?
  debtReliefApp    DebtReliefApp?
  owners           Owner[]
  tradeRefs        TradeReference[]
  bankRefs         BankReference[]
  accountantRefs   AccountantReference[]
  mcaEntries       MCAEntry[]
  documents        Document[]
  documentRequests DocumentRequest[]
  signatures       Signature[]
  matches          Match[]
  offers           Offer[]
  funding          Funding?
  plaidConnections PlaidConnection[]
  servicingEvents  ServicingEvent[]
  capitalEnh       CapitalEnhancement?
  auditLogs        AuditLog[]

  @@index([applicantUserId])
  @@index([referralAgentId])
  @@index([status])
  @@index([loanType])
  @@index([resumeToken])
}

model QuickApp {
  id                      String  @id @default(cuid())
  applicationId           String  @unique
  // Contact
  firstName               String
  lastName                String
  businessEmail           String
  cellPhone               String
