# ─────────────────────────────────────────────────────────────
# Trinity Finance - Environment Variables
# Copy to .env.local for local development
# NEVER commit .env files to version control
# ─────────────────────────────────────────────────────────────

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://trinityfinance.com
NODE_ENV=development
PORT=3000

# ── Database (Railway PostgreSQL in production) ──────────────
DATABASE_URL=postgresql://trinity:trinity_local_pw@localhost:5432/trinity_finance

# ── Redis (Railway Redis in production) ─────────────────────
REDIS_URL=redis://localhost:6379

# ── Encryption (AES-256-GCM for PII fields) ─────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_hex_char_key_here_generate_with_openssl_rand_hex_32

# ── Clerk Authentication ─────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/partner
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/apply

# ── Anthropic (Claude API) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── AWS ─────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=trinity-finance-docs-prod
# KMS key for S3 encryption (optional - uses default S3 KMS if not set)
AWS_KMS_KEY_ID=arn:aws:kms:us-east-1:...

# ── Plaid ────────────────────────────────────────────────────
PLAID_CLIENT_ID=...
PLAID_SECRET=...
PLAID_ENV=sandbox  # sandbox | development | production
NEXT_PUBLIC_PLAID_ENV=sandbox

# ── Resend (Email) ───────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@trinityfinance.com
OPS_EMAIL=ops@trinityfinance.com

# ── Twilio (SMS) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+17405550100

# ── Sentry (Error Monitoring) ────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=trinity-finance
SENTRY_PROJECT=trinity-finance-web

# ── Axiom (Structured Logging) ───────────────────────────────
AXIOM_TOKEN=...
AXIOM_DATASET=trinity-finance-prod

# ── Stripe (Phase 4 - Loan Servicing Payments) ───────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Feature Flags ────────────────────────────────────────────
FEATURE_FLAG_PLAID=false          # Enable Phase 3 Plaid integration
FEATURE_FLAG_MARKETPLACE=false    # Enable Phase 5 Marketplace
FEATURE_FLAG_CAPITAL_ENH=false    # Enable Phase 6 Capital Enhancement
FEATURE_FLAG_AI_INTAKE=true       # Enable 10-question agentic intake
