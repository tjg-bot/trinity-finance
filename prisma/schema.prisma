// ─────────────────────────────────────────────────────────────
// PRINCIPALS / OWNERS
// ─────────────────────────────────────────────────────────────

model Owner {
  id                String    @id @default(cuid())
  applicationId     String
  fullName          String
  bestPhone         String
  title             String
  homeAddress       String
  // PII - stored encrypted
  dateOfBirth       String    // AES-256-GCM encrypted
  bestEmail         String
  personalFico      String
  ssn               String    // AES-256-GCM encrypted
  dlState           String
  dlNumber          String    // AES-256-GCM encrypted
  ownershipPercent  String
  equityInOtherBiz  Boolean   @default(false)
  equityExplain     String?
  isPrimary         Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  application Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
}

// ─────────────────────────────────────────────────────────────
// REFERENCES
// ─────────────────────────────────────────────────────────────

model TradeReference {
  id              String    @id @default(cuid())
  applicationId   String
  companyName     String
  phone           String
  address         String
  contactName     String
  contactEmail    String?
  association     String?
  relationshipLen String?
  createdAt       DateTime  @default(now())
  deletedAt       DateTime?

  application Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
}

model BankReference {
  id            String    @id @default(cuid())
  applicationId String
  bankName      String
  address       String
  contactPerson String?
  phone         String?
  // PII - encrypted
  accountNumbers String   // AES-256-GCM encrypted (JSON array)
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?

  application Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
}

model AccountantReference {
  id            String    @id @default(cuid())
  applicationId String
  accountantName String
  address       String
  email         String?
  telephone     String?
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?

  application Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
}

model MCAEntry {
  id            String    @id @default(cuid())
  applicationId String
  lenderName    String
  amount        String
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?

  application Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
}

// ─────────────────────────────────────────────────────────────
// DOCUMENTS
// ─────────────────────────────────────────────────────────────

model Document {
  id                String          @id @default(cuid())
  applicationId     String
  docType           DocType
  s3Key             String
  s3Bucket          String
  originalFilename  String
  mimeType          String
  sizeBytes         Int
  stoplightStatus   StoplightStatus @default(PENDING)
  aiAnalysis        Json?
  clarificationNote String?
  uploadedByUserId  String?
  virusScanPassed   Boolean?
  textractJobId     String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  application      Application      @relation(fields: [applicationId], references: [id])
  documentRequests DocumentRequest[]

  @@index([applicationId])
  @@index([stoplightStatus])
  @@index([docType])
}

model DocumentRequest {
  id              String    @id @default(cuid())
  applicationId   String
  docType         DocType
  documentId      String?
  followUpCount   Int       @default(0)
  lastFollowUpAt  DateTime?
  followUpHistory Json      @default("[]")
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  application Application @relation(fields: [applicationId], references: [id])
  document    Document?   @relation(fields: [documentId], references: [id])

  @@index([applicationId])
  @@index([docType])
}

// ─────────────────────────────────────────────────────────────
// SIGNATURES
// ─────────────────────────────────────────────────────────────

model Signature {
  id            String   @id @default(cuid())
  applicationId String
  signerUserId  String?
  signerName    String
  signerTitle   String
  businessName  String
  // PII - s3Key to encrypted PNG
  signaturePngS3Key String // AES-256-GCM encrypted reference
  ip            String
  userAgent     String
  signedAt      DateTime @default(now())
  deletedAt     DateTime?

  application Application @relation(fields: [applicationId], references: [id])
  signer      User?       @relation(fields: [signerUserId], references: [id])

  @@index([applicationId])
}

// ─────────────────────────────────────────────────────────────
// BANK RULES & MATCHING
// ─────────────────────────────────────────────────────────────

model BankRule {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  criteria       Json      // DSCR thresholds, FICO bands, industries, states, deal size, TIB
  offerTemplates Json      // Tiered rate/term logic
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  matches      Match[]

  @@index([organizationId])
}

model Match {
  id              String      @id @default(cuid())
  applicationId   String
  organizationId  String
  bankRuleId      String
  score           Int         // 0-100
  projectedTerms  Json        // rate, term, monthly payment, total cost, time-to-close
  status          MatchStatus @default(PROPOSED)
  isAnonymized    Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  application  Application @relation(fields: [applicationId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  bankRule     BankRule    @relation(fields: [bankRuleId], references: [id])
  offer        Offer?

  @@index([applicationId])
  @@index([organizationId])
  @@index([score])
}

model Offer {
  id               String    @id @default(cuid())
  applicationId    String
  matchId          String    @unique
  rate             Float
  termMonths       Int
  amount           Float
  fees             Float
  selectedAt       DateTime?
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  application Application @relation(fields: [applicationId], references: [id])
  match       Match       @relation(fields: [matchId], references: [id])
  funding     Funding?

  @@index([applicationId])
}

model Funding {
  id                    String    @id @default(cuid())
  applicationId         String    @unique
  offerId               String    @unique
  amount                Float
  fundedDate            DateTime
  originatorCommission  Float
  underwritingFee       Float
  servicingSpread       Float
  lenderSubmissionPdfS3Key String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  application Application @relation(fields: [applicationId], references: [id])
  offer       Offer       @relation(fields: [offerId], references: [id])

  @@index([applicationId])
}

// ─────────────────────────────────────────────────────────────
// PHASE 3 - PLAID + SERVICING
// ─────────────────────────────────────────────────────────────

model PlaidConnection {
  id              String    @id @default(cuid())
  applicationId   String
  userId          String
  itemId          String    @unique
  // PII - encrypted
  accessToken     String    // AES-256-GCM encrypted
  institutionId   String?
  institutionName String?
  lastSyncAt      DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  application Application @relation(fields: [applicationId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@index([applicationId])
}

model ServicingEvent {
  id            String             @id @default(cuid())
  applicationId String
  eventType     ServicingEventType
  payload       Json
  triggeredAt   DateTime           @default(now())
  resolvedAt    DateTime?
  notifiedAt    DateTime?
  createdAt     DateTime           @default(now())
  deletedAt     DateTime?

  application Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
  @@index([eventType])
}

// ─────────────────────────────────────────────────────────────
// PHASE 5 - MARKETPLACE
// ─────────────────────────────────────────────────────────────

model MarketplaceListing {
  id             String                   @id @default(cuid())
  bankId         String
  loanIds        Json                     // Array of Funding IDs
  price          Float
  status         MarketplaceListingStatus @default(ACTIVE)
  performanceGrade String?
  projectedYield Float?
  tags           Json                     @default("[]")
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  deletedAt      DateTime?

  trades MarketplaceTrade[] @relation("ListingTrades")

  @@index([bankId])
  @@index([status])
}

model MarketplaceTrade {
  id          String    @id @default(cuid())
  listingId   String
  buyerOrgId  String
  sellerOrgId String
  price       Float
  executedAt  DateTime  @default(now())
  deletedAt   DateTime?

  listing MarketplaceListing @relation("ListingTrades", fields: [listingId], references: [id])

  @@index([listingId])
}

// ─────────────────────────────────────────────────────────────
// PHASE 6 - CAPITAL ENHANCEMENT
// ─────────────────────────────────────────────────────────────

model CapitalEnhancement {
  id                    String    @id @default(cuid())
  applicationId         String    @unique
  nmtcEligible          Boolean   @default(false)
  ozEligible            Boolean   @default(false)
  ssbciEligible         Boolean   @default(false)
  stateGuaranteeEligible Boolean  @default(false)
  madeInAmericaEligible Boolean   @default(false)
  eligibilityDetail     Json      @default("{}")
  reportingDocS3Keys    Json      @default("[]")
  processedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  application Application @relation(fields: [applicationId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// AUDIT + WEBHOOKS
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(cuid())
  actorUserId   String?
  action        String   // e.g., "READ_PII", "STATUS_CHANGE", "DOC_UPLOAD"
  entity        String   // e.g., "Application", "Document"
  entityId      String
  applicationId String?
  before        Json?
  after         Json?
  ip            String?
  userAgent     String?
  ts            DateTime @default(now())

  actor       User?       @relation("AuditActor", fields: [actorUserId], references: [id])
  application Application? @relation(fields: [applicationId], references: [id])

  @@index([actorUserId])
  @@index([entityId])
  @@index([applicationId])
  @@index([ts])
}

model WebhookEvent {
  id          String   @id @default(cuid())
  source      String   // "plaid" | "twilio" | "resend" | "clerk"
  eventType   String
  payload     Json
  processedAt DateTime?
  error       String?
  createdAt   DateTime @default(now())

  @@index([source])
  @@index([processedAt])
}
