  annualRevenue           String
  netIncomeEbitda         String
  ficoScore               String
  bankAccountType         String
  // Funding Details
  useOfFunds              String
  urgency                 String
  backgroundInfo          String
  homeOwnership           String
  homeOwnershipOther      String?
  desiredFundingAmount    String
  // Current Debt
  hasDebt                 Boolean @default(false)
  totalDebtAmount         String?
